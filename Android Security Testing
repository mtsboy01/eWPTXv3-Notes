## 🪝 Frida Dynamic Instrumentation

```bash
# Start frida server on device
adb push frida-server /data/local/tmp/
adb shell chmod 755 /data/local/tmp/frida-server
adb shell /data/local/tmp/frida-server &

# List running apps
frida-ps -U

# Attach to running app
frida -U -n "App Name" -l script.js

# Spawn app
frida -U -f com.target.app -l script.js --no-pause

# Example Frida script - Hook function
Java.perform(function() {
  var MainActivity = Java.use('com.target.app.MainActivity');
  MainActivity.checkPassword.implementation = function(password) {
    console.log('Password checked: ' + password);
    return true;  // bypass check
  };
});

# Dump all method calls
Java.perform(function() {
  Java.enumerateLoadedClasses({
    onMatch: function(name) { console.log(name); },
    onComplete: function() {}
  });
});
```

