/uploads/
/files/
/media/
/images/
/static/uploads/
/wp-content/uploads/   (WordPress)
/storage/              (Laravel)

# Brute force with gobuster
gobuster dir -u https://target.com -w /usr/share/wordlists/dirb/common.txt
